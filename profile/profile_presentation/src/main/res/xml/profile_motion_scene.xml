<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Transition
        app:constraintSetEnd="@id/end"
        app:constraintSetStart="@id/start"
        app:duration="450">

        <OnClick
            app:clickAction="toggle"
            app:targetId="@id/photo_menu_container" />

        <KeyFrameSet>

            <KeyAttribute
                android:scaleX="2"
                android:scaleY="1"
                app:framePosition="50"
                app:motionTarget="@id/photo_menu_container" />

        </KeyFrameSet>
    </Transition>

    <ConstraintSet android:id="@+id/start">

        <Constraint
            android:id="@id/photo_menu_container"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="140dp"
            app:cardCornerRadius="28dp"
            app:layout_constraintEnd_toEndOf="@id/cv_user_image_profile"
            app:layout_constraintTop_toTopOf="@id/cv_user_image_profile" />

    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">

        <Constraint
            android:id="@id/photo_menu_container"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="140dp"
            app:cardCornerRadius="24dp"
            app:layout_constraintEnd_toEndOf="@id/cv_user_image_profile"
            app:layout_constraintTop_toTopOf="@id/cv_user_image_profile" />

    </ConstraintSet>

</MotionScene>